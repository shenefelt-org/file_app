<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">

  <style>
    :root {
        --pico-font-family-sans-serif: Verdana, sans-serif;
        --pico-background-color: #f0e6ff;
        --pico-color: #9d84b7;
        --pico-h1-color: #9d84b7;
        --pico-primary: #c8b6ff;
        --pico-primary-hover: #9d84b7;
        --pico-primary-underline: rgba(200, 182, 255, 0.5);
    }

    body {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        background-color: #f0e6ff;
        margin: 0;
        font-family: Verdana, sans-serif;
    }

    .hero-octopus-container {
        position: relative;
        width: 120px;
        height: 140px;
        margin: 40px auto 0.25rem auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: float 3s ease-in-out infinite;
    }

    .octo-head {
        width: 90px;
        height: 80px;
        background: #c8b6ff;
        border-radius: 45px 45px 18px 18px;
        position: relative;
        box-shadow: inset -6px -6px 0 rgba(157, 132, 183, 0.3);
        z-index: 2;
    }

    .octo-eye {
        width: 16px;
        height: 16px;
        background: #ffffff;
        border-radius: 50%;
        position: absolute;
        top: 40px;
        box-shadow: 0 2px 4px rgba(157, 132, 183, 0.2);
    }

    .octo-eye::after {
        content: '';
        position: absolute;
        width: 7px;
        height: 7px;
        background: #9d84b7;
        border-radius: 50%;
        top: 5px;
        right: 2px;
    }

    .eye-left { left: 20px; }
    .eye-right { right: 20px; }

    .octo-tentacles {
        display: flex;
        gap: 6px;
        margin-top: -12px;
        z-index: 1;
    }

    .tentacle {
        width: 16px;
        background: #c8b6ff;
        border-radius: 10px;
        box-shadow: inset -2px -2px 0 rgba(157, 132, 183, 0.3);
        transform-origin: top center;
        animation: swim 1.5s ease-in-out infinite alternate;
    }

    .t1 { animation-delay: 0.0s; height: 36px; }
    .t2 { animation-delay: 0.2s; height: 44px; }
    .t3 { animation-delay: 0.4s; height: 44px; }
    .t4 { animation-delay: 0.6s; height: 36px; }

    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
    }

    @keyframes swim {
        0% { transform: rotate(-8deg) translateY(0); }
        100% { transform: rotate(8deg) translateY(-4px); }
    }

    .ollie-caption {
        text-align: center;
        color: #9d84b7;
        font-style: italic;
        font-weight: bolder;
        font-size: 0.85rem;
        opacity: 0.7;
        margin-top: 0;
        margin-bottom: 1.5rem;
    }

    h1 {
        font-size: 2.3rem;
        font-weight: 800;
        color: #9d84b7;
        margin-bottom: 2rem;
    }

    .highlight { color: #c8b6ff; }

    .setup-card {
        max-width: 480px;
        margin: 0 auto 40px auto;
        background-color: #ffffff;
        border: 2px solid #c8b6ff;
        border-radius: 1rem;
        box-shadow: 0 8px 16px rgba(157, 132, 183, 0.1);
        padding: 2.5rem;
        text-align: left;
    }

    .qr-box {
        background: #fbf9ff;
        border: 2px dashed #c8b6ff;
        padding: 1.5rem;
        border-radius: 0.75rem;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .qr-box svg {
        fill: #9d84b7 !important;
    }

    input[type="text"] {
        background-color: #ffffff;
        border: 2px solid #c8b6ff;
        color: #9d84b7;
        border-radius: 0.75rem;
        text-align: center;
        font-size: 1.25rem;
        letter-spacing: 4px;
        font-weight: bold;
    }

    input[type="text"]:focus {
        border-color: #9d84b7;
        box-shadow: 0 0 0 3px rgba(200, 182, 255, 0.5);
    }

    .pico-btn {
        background-color: #c8b6ff;
        border-color: #c8b6ff;
        color: #ffffff;
        border-radius: 2rem;
        padding: 0.75rem 2rem;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        display: block;
        width: 100%;
        margin-top: 1.5rem;
        text-align: center;
        cursor: pointer;
    }

    .pico-btn:hover {
        background-color: #9d84b7;
        border-color: #9d84b7;
    }

    .back-link {
        display: block;
        text-align: center;
        margin-top: 1.5rem;
        color: #9d84b7;
        text-decoration: underline;
    }
  </style>
</head>

<body>
  <main class="container">
    <div class="hero-octopus-container">
      <div class="octo-head"><div class="octo-eye eye-left"></div><div class="octo-eye eye-right"></div></div>
      <div class="octo-tentacles"><div class="tentacle t1"></div><div class="tentacle t2"></div><div class="tentacle t3"></div><div class="tentacle t4"></div></div>
    </div>
    <p class="ollie-caption">Moi, c'est Peri.</p>

    <h1>Secure <span class="highlight">Your Account</span></h1>

    <div class="setup-card">
      <p style="font-size: 0.95rem; margin-bottom: 1.25rem; color: #9d84b7;">
        Scan this verification pattern using your preferred authenticator app:
      </p>

      <div class="qr-box">
        <%= @qrcode.html_safe %>
      </div>

      <%= form_with url: two_factor_settings_path, method: :post, local: true, data: { turbo: false } do |f| %>
        <div style="margin-bottom: 1rem;">
          <label style="font-weight:600; color:#9d84b7; margin-bottom:0.5rem;">Enter 6-Digit Verification Token</label>
          <%= f.text_field :code, autocomplete: "one-time-code", required: true, maxlength: 6, placeholder: "000000" %>
        </div>

        <%= f.submit "Activate Two-Factor Authentication", class: "pico-btn" %>
      <% end %>

      <%= link_to "← Return to System Dashboard", root_path, class: "back-link" %>
    </div>
  </main>
</body>
