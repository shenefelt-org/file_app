<%# app/views/admin/users/index.html.erb %>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">

  <style>
    /* 1. Override Pico defaults with your Periwinkle palette */
    :root {
        --pico-font-family-sans-serif: Verdana, sans-serif;
        --pico-background-color: #f0e6ff;
        --pico-color: #9d84b7;
        --pico-h1-color: #9d84b7;
        --pico-h3-color: #9d84b7;
        --pico-primary: #c8b6ff;
        --pico-primary-hover: #9d84b7;
        --pico-primary-underline: rgba(200, 182, 255, 0.5);
    }

    /* 2. Layout Framework */
    body {
        background-color: #f0e6ff;
        margin: 0;
        font-family: Verdana, sans-serif;
        color: #9d84b7;
    }

    .scaffold-container {
        max-width: 950px;
        margin: 40px auto;
        padding: 0 20px;
    }

    /* 3. Peri Character Animation Mechanics */
    .hero-octopus-container {
        position: relative;
        width: 120px;
        height: 140px;
        margin: 0 auto 0.25rem auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: float 3s ease-in-out infinite;
    }

    .octo-head {
        width: 90px;
        height: 80px;
        background: #c8b6ff;
        border-radius: 45px 45px 18px 18px;
        position: relative;
        box-shadow: inset -6px -6px 0 rgba(157, 132, 183, 0.3);
        z-index: 2;
    }

    .octo-eye {
        width: 16px;
        height: 16px;
        background: #ffffff;
        border-radius: 50%;
        position: absolute;
        top: 40px;
        box-shadow: 0 2px 4px rgba(157, 132, 183, 0.2);
    }

    .octo-eye::after {
        content: '';
        position: absolute;
        width: 7px;
        height: 7px;
        background: #9d84b7;
        border-radius: 50%;
        top: 5px;
        right: 2px;
    }

    .eye-left { left: 20px; }
    .eye-right { right: 20px; }

    .octo-tentacles {
        display: flex;
        gap: 6px;
        margin-top: -12px;
        z-index: 1;
    }

    .tentacle {
        width: 16px;
        background: #c8b6ff;
        border-radius: 10px;
        box-shadow: inset -2px -2px 0 rgba(157, 132, 183, 0.3);
        transform-origin: top center;
        animation: swim 1.5s ease-in-out infinite alternate;
    }

    .t1 { animation-delay: 0.0s; height: 36px; }
    .t2 { animation-delay: 0.2s; height: 44px; }
    .t3 { animation-delay: 0.4s; height: 44px; }
    .t4 { animation-delay: 0.6s; height: 36px; }

    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
    }

    @keyframes swim {
        0% { transform: rotate(-8deg) translateY(0); }
        100% { transform: rotate(8deg) translateY(-4px); }
    }

    .ollie-caption {
        text-align: center;
        color: #9d84b7;
        font-style: italic;
        font-weight: bolder;
        font-size: 0.85rem;
        opacity: 0.7;
        margin-top: 0;
        margin-bottom: 1.5rem;
    }

    /* 4. Layout Headers and Tables */
    .header-group {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 2rem;
        margin-bottom: 1.5rem;
    }

    h1 {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0;
        color: #9d84b7;
    }

    h1 span.highlight {
        color: #c8b6ff;
    }

    .table-container {
        border: 2px solid #c8b6ff;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 8px 16px rgba(157, 132, 183, 0.1);
        background: #ffffff;
    }

    table {
        margin-bottom: 0;
    }

    thead tr {
        background-color: #c8b6ff !important;
    }

    thead th {
        color: #ffffff !important;
        font-weight: bold;
        padding: 14px;
    }

    tbody td {
        padding: 14px;
        vertical-align: middle;
        color: #9d84b7;
    }

    tbody tr {
        border-bottom: 1px solid #f0e6ff;
    }

    tbody tr:last-child {
        border-bottom: none;
    }

    .badge-admin {
        background-color: #9d84b7;
        color: #ffffff;
        padding: 0.25rem 0.6rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .badge-user {
        background-color: #f0e6ff;
        color: #9d84b7;
        padding: 0.25rem 0.6rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    /* Action Links Style */
    .action-link {
        color: #9d84b7;
        font-weight: 600;
        text-decoration: underline;
        text-decoration-color: var(--pico-primary-underline);
        margin-right: 0.75rem;
    }

    .action-link:hover {
        color: #c8b6ff;
    }

    .delete-link {
        color: #ff6b6b;
        text-decoration: underline;
    }

    .delete-link:hover {
        color: #d94848;
    }

    /* 5. Custom Button Configuration */
    .pico-btn {
        background-color: #c8b6ff;
        border-color: #c8b6ff;
        color: #ffffff;
        border-radius: 2rem;
        padding: 0.6rem 1.5rem;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 0.5px;
        transition: background-color 0.2s ease, border-color 0.2s ease;
        text-decoration: none;
        font-size: 0.85rem;
        display: inline-block;
    }

    .pico-btn:hover {
        background-color: #9d84b7;
        border-color: #9d84b7;
        color: #ffffff;
    }

    .nav-back {
        margin-top: 1.5rem;
        display: block;
        color: #9d84b7;
    }
  </style>
</head>

<body>
  <main class="scaffold-container">

    <!-- Peri Character Header Branding -->
    <div class="hero-octopus-container">
      <div class="octo-head">
        <div class="octo-eye eye-left"></div>
        <div class="octo-eye eye-right"></div>
      </div>
      <div class="octo-tentacles">
        <div class="tentacle t1"></div>
        <div class="tentacle t2"></div>
        <div class="tentacle t3"></div>
        <div class="tentacle t4"></div>
      </div>
    </div>
    <p class="ollie-caption">Moi, c'est Peri.</p>

    <!-- Notices Dynamic Rendering -->
    <% if notice.present? %>
      <div style="background-color: #e6fffa; color: #234e52; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem; border: 1px solid #b2f5ea; text-align:center;">
        <%= notice %>
      </div>
    <% end %>

    <div class="header-group">
      <h1>User <span class="highlight">Scaffold Directory</span></h1>
      <%= link_to "Add New User", new_admin_user_path, class: "pico-btn" %>
    </div>

    <!-- Main Data Table Logs -->
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Email Address</th>
            <th>Access Level</th>
            <th style="text-align: right;">Administrative Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><strong><%= user.email %></strong></td>
              <td>
                <% if user.admin? %>
                  <span class="badge-admin">Admin</span>
                <% else %>
                  <span class="badge-user">User</span>
                <% end %>
              </td>
              <td style="text-align: right;">
                <%= link_to "View", [:admin, user], class: "action-link" %>
                <%= link_to "Edit", edit_admin_user_path(user), class: "action-link" %>
                <%= link_to "Delete", [:admin, user], data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to remove this user account?" }, class: "action-link delete-link" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= link_to "← Back to System Dashboard", root_path, class: "nav-back" %>

  </main>
</body>
