<%# app/views/admin/users/new.html.erb %>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">

  <style>
    /* 1. Override Pico defaults with your Periwinkle palette */
    :root {
        --pico-font-family-sans-serif: Verdana, sans-serif;
        --pico-background-color: #f0e6ff;
        --pico-color: #9d84b7;
        --pico-h1-color: #9d84b7;
        --pico-primary: #c8b6ff;
        --pico-primary-hover: #9d84b7;
        --pico-primary-underline: rgba(200, 182, 255, 0.5);
    }

    /* 2. Layout Framework */
    body {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        background-color: #f0e6ff;
        margin: 0;
        font-family: Verdana, sans-serif;
    }

    /* 3. Peri Character Animation Mechanics */
    .hero-octopus-container {
        position: relative;
        width: 120px;
        height: 140px;
        margin: 40px auto 0.25rem auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: float 3s ease-in-out infinite;
    }

    .octo-head {
        width: 90px;
        height: 80px;
        background: #c8b6ff;
        border-radius: 45px 45px 18px 18px;
        position: relative;
        box-shadow: inset -6px -6px 0 rgba(157, 132, 183, 0.3);
        z-index: 2;
    }

    .octo-eye {
        width: 16px;
        height: 16px;
        background: #ffffff;
        border-radius: 50%;
        position: absolute;
        top: 40px;
        box-shadow: 0 2px 4px rgba(157, 132, 183, 0.2);
    }

    .octo-eye::after {
        content: '';
        position: absolute;
        width: 7px;
        height: 7px;
        background: #9d84b7;
        border-radius: 50%;
        top: 5px;
        right: 2px;
    }

    .eye-left { left: 20px; }
    .eye-right { right: 20px; }

    .octo-tentacles {
        display: flex;
        gap: 6px;
        margin-top: -12px;
        z-index: 1;
    }

    .tentacle {
        width: 16px;
        background: #c8b6ff;
        border-radius: 10px;
        box-shadow: inset -2px -2px 0 rgba(157, 132, 183, 0.3);
        transform-origin: top center;
        animation: swim 1.5s ease-in-out infinite alternate;
    }

    .t1 { animation-delay: 0.0s; height: 36px; }
    .t2 { animation-delay: 0.2s; height: 44px; }
    .t3 { animation-delay: 0.4s; height: 44px; }
    .t4 { animation-delay: 0.6s; height: 36px; }

    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
    }

    @keyframes swim {
        0% { transform: rotate(-8deg) translateY(0); }
        100% { transform: rotate(8deg) translateY(-4px); }
    }

    .ollie-caption {
        text-align: center;
        color: #9d84b7;
        font-style: italic;
        font-weight: bolder;
        font-size: 0.85rem;
        opacity: 0.7;
        margin-top: 0;
        margin-bottom: 1.5rem;
    }

    /* 4. Typography & Container Cards */
    h1 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-top: 0;
        margin-bottom: 2rem;
        color: #9d84b7;
    }

    h1 span.highlight {
        color: #c8b6ff;
    }

    .form-card {
        max-width: 500px;
        margin: 0 auto 40px auto;
        text-align: left;
        background-color: #ffffff;
        border: 2px solid #c8b6ff;
        border-radius: 1rem;
        box-shadow: 0 8px 16px rgba(157, 132, 183, 0.1);
        padding: 2.5rem;
    }

    .form-field {
        margin-bottom: 1.25rem;
    }

    .form-field label {
        color: #9d84b7;
        font-weight: 600;
        margin-bottom: 0.4rem;
    }

    input[type="email"], 
    input[type="password"] {
        background-color: #ffffff;
        border: 2px solid #c8b6ff;
        color: #9d84b7;
        border-radius: 0.75rem;
    }

    input[type="email"]:focus, 
    input[type="password"]:focus {
        border-color: #9d84b7;
        box-shadow: 0 0 0 3px rgba(200, 182, 255, 0.5);
    }

    .checkbox-container {
        display: flex;
        align-items: center;
        margin: 1.5rem 0;
        padding: 0.75rem;
        background-color: #f0e6ff;
        border-radius: 0.5rem;
    }

    .checkbox-container label {
        margin-bottom: 0;
        cursor: pointer;
        font-weight: bold;
    }

    /* 5. Custom Button */
    .pico-btn {
        background-color: #c8b6ff;
        border-color: #c8b6ff;
        color: #ffffff;
        border-radius: 2rem;
        padding: 0.75rem 2rem;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        transition: background-color 0.2s ease, border-color 0.2s ease;
        display: block;
        width: 100%;
        margin-top: 1.5rem;
        text-align: center;
        cursor: pointer;
    }

    .pico-btn:hover {
        background-color: #9d84b7;
        border-color: #9d84b7;
        color: #ffffff;
    }

    .back-link {
        display: block;
        text-align: center;
        margin-top: 1.5rem;
        color: #9d84b7;
        text-decoration: underline;
        text-decoration-color: var(--pico-primary-underline);
        font-size: 0.95rem;
    }

    .back-link:hover {
        color: #c8b6ff;
    }

    .error-messages {
        color: #ff6b6b;
        background-color: #ffe3e3;
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }
  </style>
</head>

<body>
  <main class="container">

    <!-- Peri Brand Identification -->
    <div class="hero-octopus-container">
      <div class="octo-head">
        <div class="octo-eye eye-left"></div>
        <div class="octo-eye eye-right"></div>
      </div>
      <div class="octo-tentacles">
        <div class="tentacle t1"></div>
        <div class="tentacle t2"></div>
        <div class="tentacle t3"></div>
        <div class="tentacle t4"></div>
      </div>
    </div>
    <p class="ollie-caption">Moi, c'est Peri.</p>

    <h1>Create <span class="highlight">New User</span></h1>

    <!-- Embedded Scaffold Form Card -->
    <div class="form-card">
      <%= form_with(model: [:admin, @user], local: true) do |f| %>
        
        <% if @user.errors.any? %>
          <div class="error-messages">
            <strong>Please resolve the following errors:</strong>
            <ul>
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-field">
          <%= f.label :email, "Account Email Address" %>
          <%= f.email_field :email, autofocus: true, required: true, placeholder: "employee@company.com" %>
        </div>

        <div class="form-field">
          <%= f.label :password, "Temporary Password" %>
          <%= f.password_field :password, required: true, placeholder: "••••••••" %>
        </div>

        <div class="form-field">
          <%= f.label :password_confirmation, "Confirm Temporary Password" %>
          <%= f.password_field :password_confirmation, required: true, placeholder: "••••••••" %>
        </div>

        <div class="checkbox-container">
          <label for="user_admin">
            <%= f.check_box :admin %>
            Grant Administrator Privileges
          </label>
        </div>

        <%= f.submit "Provision User Account", class: "pico-btn" %>
      <% end %>

      <%= link_to "← Return to System Dashboard", root_path, class: "back-link" %>
    </div>

  </main>
</body>
